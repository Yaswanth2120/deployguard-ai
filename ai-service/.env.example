# OpenRouter API key for real model calls. Leave blank to use fallback mode.
OPENROUTER_API_KEY=

# Defaults used by the AI service when unset, where supported by the application.
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Current application timeout is 30 seconds.
OPENROUTER_TIMEOUT_SECONDS=30
